; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="shiso"
run/main_scene="uid://7glennwisk38"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="uid://croowb1h1obu1"

[autoload]

global_item="*uid://bepjdm5epf4is"
global_vars="*uid://boy5nj1yidr8b"

[display]

window/size/viewport_width=640
window/size/viewport_height=320
window/size/mode=1
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_super-wakatime/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://assets/": "pink",
"res://code/": "blue",
"res://code/general/": "purple",
"res://code/inventory_and_items/": "teal",
"res://code/map/": "yellow",
"res://code/player/": "pink",
"res://code/systems/coins/": "orange",
"res://code/systems/health/": "red",
"res://exports/": "orange"
}

